<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/frag_video"
        android:name="com.nathanhaze.gifcreator.fragment.VideoFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:maxHeight="300dp"
        tools:layout="@layout/fragment_video"
        tools:layout_height="80dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Frame frequency -->
            <androidx.cardview.widget.CardView style="@style/cardview">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_freq"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/range_frequency"
                        android:textColor="@color/card_text" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/frame_rate"
                        style="@style/Base.Sephiroth.Widget.RangeSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:valueFrom="40"
                        android:valueTo="1000" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Item 2: Playback speed -->
            <androidx.cardview.widget.CardView style="@style/cardview">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_speed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/playback_speed"
                        android:textColor="@color/card_text" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/s_speed"
                        style="@style/Base.Sephiroth.Widget.RangeSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:stepSize="1"
                        android:value="4"
                        android:valueFrom="1"
                        android:valueTo="8" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Time range -->
            <androidx.cardview.widget.CardView style="@style/cardview">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/set_start_and_end_time"
                        android:textColor="@color/card_text" />

                    <com.google.android.material.slider.RangeSlider
                        android:id="@+id/range_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tv_start_time"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="00:00"
                            android:textColor="@color/card_text" />

                        <TextView
                            android:id="@+id/tv_end_time"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="00:00"
                            android:textColor="@color/card_text" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bitmap size -->
            <androidx.cardview.widget.CardView style="@style/cardview">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bitmap_size"
                        android:textColor="@color/card_text" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/s_size"
                        style="@style/Base.Sephiroth.Widget.RangeSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:value="100"
                        android:valueFrom="10"
                        android:valueTo="100" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Item 4: Aspect ratio -->
            <androidx.cardview.widget.CardView style="@style/cardview">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/aspect_ratio"
                        android:textColor="@color/card_text" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/cg_aspect_ratio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        ads:singleSelection="true"
                        ads:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_ar_original"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ar_original" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_ar_square"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ar_square" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_ar_four_three"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ar_four_three" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_ar_sixteen_nine"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ar_sixteen_nine" />
                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Filter strip -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_add_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/add_a_filter"
                    android:textColor="@color/card_text" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_filters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_add_filter" />

            </RelativeLayout>

            <!-- Item 7: Caption / text overlay -->
            <androidx.cardview.widget.CardView style="@style/cardview">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/add_caption">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Reverse order -->
            <androidx.cardview.widget.CardView style="@style/cardview">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/reverse_order"
                        android:textColor="@color/card_text" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_reverse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Forward + Reverse (hidden by default) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/forward_plus_reverse"
                    android:textColor="@color/card_text" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_double"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Item 8: Loop count -->
            <androidx.cardview.widget.CardView style="@style/cardview">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_loop_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/loop_count_infinite"
                        android:textColor="@color/card_text" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/s_loop_count"
                        style="@style/Base.Sephiroth.Widget.RangeSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:stepSize="1"
                        android:value="0"
                        android:valueFrom="0"
                        android:valueTo="10" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Item 1: Frame preview strip -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_frame_preview_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/frame_preview"
                    android:textColor="@color/card_text" />

                <TextView
                    android:id="@+id/tv_preview_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_frame_preview_label"
                    android:text="@string/loading_preview"
                    android:textColor="@color/card_text"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_frame_preview"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_below="@id/tv_frame_preview_label"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:visibility="gone" />

            </RelativeLayout>

            <!-- Info + warning -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_warning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:src="@drawable/ic_warning"
                    android:visibility="invisible" />

                <TextView
                    android:id="@+id/tv_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:padding="8dp"
                    android:text="@string/create_gif"
                    android:textColor="@color/card_text" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_create_gif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:padding="16dp"
                android:text="@string/create_gif" />

            <com.google.android.gms.ads.AdView
                android:id="@+id/adView"
                style="@style/ad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                ads:adSize="BANNER"
                ads:adUnitId="@string/banner_ad_unit_id" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
