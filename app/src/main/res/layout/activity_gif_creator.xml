<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".activity.GifCreatorActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:fontFamily="@font/old_type"
                android:gravity="center"
                android:textColor="@color/primaryTextColor"
                android:textSize="16sp"
                tools:text="TEST" />

            <!-- Item 3: ETA / time remaining -->
            <TextView
                android:id="@+id/tv_eta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:textColor="@color/primaryTextColor"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="~12s remaining" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_circular"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <com.google.android.gms.ads.AdView
                android:id="@+id/adView_loading"
                style="@style/ad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                ads:adSize="BANNER"
                ads:adUnitId="@string/banner_ad_unit_id" />

        </LinearLayout>

        <pl.droidsonroids.gif.GifImageView
            android:id="@+id/iv_gif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            tools:layout_height="500dp"
            tools:layout_width="400dp" />

        <!-- Item 6: Per-frame editing -->
        <LinearLayout
            android:id="@+id/ll_frame_editing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/iv_gif"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:text="@string/review_frames"
                android:textColor="@color/primaryTextColor" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_frame_editor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btn_encode_selected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="40dp"
                android:text="@string/encode_selected" />

        </LinearLayout>

        <!-- Results: share / open / start over / MP4 export -->
        <LinearLayout
            android:id="@+id/ll_selection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/iv_gif"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <Button
                android:id="@+id/button_open_external"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="40dp"
                android:layout_marginRight="40dp"
                android:clickable="true"
                android:drawableLeft="@drawable/ic_open_external"
                android:focusable="true"
                android:paddingLeft="40dp"
                android:paddingTop="12dp"
                android:paddingRight="40dp"
                android:paddingBottom="12dp"
                android:text="@string/open_external_app" />

            <Button
                android:id="@+id/button_share"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="32dp"
                android:layout_marginRight="40dp"
                android:clickable="true"
                android:drawableLeft="@drawable/ic_share"
                android:focusable="true"
                android:paddingLeft="40dp"
                android:paddingTop="12dp"
                android:paddingRight="40dp"
                android:paddingBottom="12dp"
                android:text="@string/share" />

            <!-- Item 14: Export as MP4 -->
            <Button
                android:id="@+id/button_save_mp4"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="40dp"
                android:clickable="true"
                android:focusable="true"
                android:paddingLeft="40dp"
                android:paddingTop="12dp"
                android:paddingRight="40dp"
                android:paddingBottom="12dp"
                android:text="@string/save_as_mp4" />

            <Button
                android:id="@+id/button_start_over"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="32dp"
                android:layout_marginRight="40dp"
                android:clickable="true"
                android:drawableLeft="@drawable/ic_start_over"
                android:focusable="true"
                android:paddingLeft="40dp"
                android:paddingTop="12dp"
                android:paddingRight="40dp"
                android:paddingBottom="12dp"
                android:text="@string/start_over" />

            <com.google.android.gms.ads.AdView
                android:id="@+id/adView"
                style="@style/ad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                ads:adSize="BANNER"
                ads:adUnitId="@string/banner_ad_unit_id" />
        </LinearLayout>
    </RelativeLayout>
</ScrollView>
